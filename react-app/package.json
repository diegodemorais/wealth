{
  "name": "react-app",
  "version": "0.1.5",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/increment-version.js && npm run test:ci && next build && node scripts/post-build.js",
    "build:no-test": "node scripts/increment-version.js && next build && node scripts/post-build.js",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:headless": "cypress run --headless"
  },
  "dependencies": {
    "chart.js": "^4.4.7",
    "chartjs-chart-sankey": "^0.14.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "cypress": "^15.13.1",
    "cypress-axe": "^1.7.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "jsdom": "^29.0.2",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
