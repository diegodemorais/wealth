{
  "permissions": {
    "allow": [
      "Skill(update-config)",
      "Read(//Users/diegodemorais/claude/code/investimentos/**)",
      "Glob(//Users/diegodemorais/claude/code/investimentos/**)",
      "Grep(//Users/diegodemorais/claude/code/investimentos/**)",
      "mcp__discourse__discourse_read_topic",
      "mcp__discourse__discourse_read_post",
      "mcp__discourse__discourse_search",
      "mcp__discourse__discourse_filter_topics",
      "mcp__discourse__discourse_get_chat_messages",
      "mcp__discourse__discourse_get_draft",
      "mcp__discourse__discourse_get_query",
      "mcp__discourse__discourse_get_user",
      "mcp__discourse__discourse_list_user_posts",
      "mcp__discourse__discourse_list_users",
      "mcp__discourse__discourse_run_query",
      "mcp__openspace__search_skills",
      "Bash(python3 -c ':*)",
      "Bash(python3 scripts/parse_carteira.py)",
      "Bash(python3 scripts/generate_data.py)",
      "Bash(echo \"Exit code: $?\")",
      "Bash(git add:*)",
      "Bash(git commit -m ':*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "mcp__openspace__execute_task",
      "mcp__openspace__fix_skill",
      "mcp__openspace__upload_skill"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; case \"$f\" in */agentes/contexto/carteira.md|*/agentes/contexto/gatilhos.md) echo \"{\\\"systemMessage\\\": \\\"⚠️ EDIT EM ARQUIVO PROTEGIDO: $f — Bookkeeper deve atualizar. Head NAO edita SOT diretamente.\\\"}\";; esac; } 2>/dev/null || true",
            "statusMessage": "Verificando arquivo protegido..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; if [ -f \"$f\" ] && [ -s \"$f\" ]; then lines=$(wc -l < \"$f\"); echo \"{\\\"systemMessage\\\": \\\"⚠️  SOBRESCRITA TOTAL: $f ($lines linhas existentes serao substituidas. Verifique se e intencional.)\\\"}\"; fi; } 2>/dev/null || true",
            "statusMessage": "Verificando sobrescrita..."
          }
        ]
      }
    ]
  }
}
